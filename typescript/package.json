{
    "name": "sae-ts-sdk",
    "version": "1.3.3",
    "type": "module",
    "description": "TypeScript/JavaScript SDK para la API SAE — Facturación Electrónica de Hacienda CR",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist/**",
        "src/**",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "test": "jest",
        "prepublishOnly": "npm run build",
        "lint": "tsc --noEmit"
    },
    "keywords": [
        "hacienda",
        "costa rica",
        "factura electronica",
        "sae",
        "sdk",
        "signalr",
        "typescript"
    ],
    "author": {
        "name": "EskenderDev",
        "url": "https://github.com/EskenderDev"
    },
    "license": "MIT",
    "homepage": "https://github.com/EskenderDev/SAE_SDKs#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/EskenderDev/SAE_SDKs.git",
        "directory": "typescript"
    },
    "bugs": {
        "url": "https://github.com/EskenderDev/SAE_SDKs/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@types/jest": "^29.0.0",
        "@types/node": "^18.0.0",
        "jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "axios": "^1.0.0"
    },
    "peerDependencies": {
        "@microsoft/signalr": ">=6.0.0"
    },
    "peerDependenciesMeta": {
        "@microsoft/signalr": {
            "optional": true
        }
    }
}
